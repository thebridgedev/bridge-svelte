# =============================================================================
# bridge-svelte Playwright E2E Test Configuration
# =============================================================================
# Copy this file to config/.env.test.local and fill in the values.
# The .env.test.local file is gitignored and should NOT be committed.
#
# These variables are loaded by playwright.config.ts via dotenv.
#
# Legend:
#   [REQUIRED]       — must be set, no default value
#   [REQUIRED*]      — required when running that environment's project
#   [HAS DEFAULT]    — optional, default value shown in comment
# =============================================================================

# ---------------------------------------------------------------------------
# Required for all environments
# ---------------------------------------------------------------------------

# [REQUIRED] API key for bridge-api test data endpoints (same key as in bridge-api config)
PLAYWRIGHT_TEST_API_KEY=

# ---------------------------------------------------------------------------
# App setup — all have defaults, override only if needed
# ---------------------------------------------------------------------------
# The test app (BRIDGE_SVELTE_TEST_DASHBOARD) is created/reused automatically
# by global-setup.ts. No app ID needs to be configured.

# [HAS DEFAULT: playwright-e2e@thebridge.io] Owner email for the test app
# TEST_OWNER_EMAIL=playwright-e2e@thebridge.io

# [HAS DEFAULT: helloworld] Owner password for the test app
# TEST_OWNER_PASSWORD=helloworld

# [HAS DEFAULT: BRIDGE_SVELTE_TEST_DASHBOARD] App domain used by the test infrastructure
# APP_DOMAIN=BRIDGE_SVELTE_TEST_DASHBOARD

# ---------------------------------------------------------------------------
# Local environment (--project=local) — all have defaults
# ---------------------------------------------------------------------------

# [HAS DEFAULT: http://localhost:3200/auth]
# LOCAL_AUTH_BASE_URL=http://localhost:3200/auth

# [HAS DEFAULT: http://localhost:3200/cloud-views]
# LOCAL_CLOUD_VIEWS_URL=http://localhost:3200/cloud-views

# [HAS DEFAULT: http://localhost:3200]
# LOCAL_TEST_DATA_API_URL=http://localhost:3200

# ---------------------------------------------------------------------------
# Stage environment (--project=stage) — required when running stage tests
# ---------------------------------------------------------------------------

# [REQUIRED*] Uncomment and verify these when running: bun run test:e2e:stage
# STAGE_AUTH_BASE_URL=https://api-stage.thebridge.dev/auth
# STAGE_CLOUD_VIEWS_URL=https://api-stage.thebridge.dev/cloud-views
# STAGE_TEST_DATA_API_URL=https://api-stage.thebridge.dev

# ---------------------------------------------------------------------------
# Production environment (--project=prod) — required when running prod tests
# NOTE: Do NOT set auth/cloud-views URLs for prod. The plugin resolves
# production endpoints automatically — this mirrors the real user experience.
# ---------------------------------------------------------------------------

# [REQUIRED*] Uncomment when running: bun run test:e2e:prod
# PROD_TEST_DATA_API_URL=https://api.thebridge.dev

# ---------------------------------------------------------------------------
# Developer convenience — all optional
# ---------------------------------------------------------------------------

# [HAS DEFAULT: false] Set to 'true' to run tests in headed mode (shows browser)
# PLAYWRIGHT_HEADED=true

# [HAS DEFAULT: false] Set to 'true' to record all test artifacts (videos, traces, screenshots)
# PLAYWRIGHT_RECORD_ALL=true
